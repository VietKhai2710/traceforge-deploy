<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<OfficeApp xmlns="http://schemas.microsoft.com/office/appforoffice/1.1" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0" xmlns:ov="http://schemas.microsoft.com/office/taskpaneappversionoverrides" xsi:type="TaskPaneApp">
  <Id>9f96a9e7-4c70-4d9b-96c3-7f8d5d9f0001</Id>
  <Version>1.0.0.0</Version>
  <ProviderName>TraceForge</ProviderName>
  <DefaultLocale>en-US</DefaultLocale>
  <DisplayName DefaultValue="TraceForge"/>
  <Description DefaultValue="Fast formula map, base/delta, and formula explorer for financial model review."/>
  <IconUrl DefaultValue="https://localhost:3000/assets/icon-32.png"/>
  <HighResolutionIconUrl DefaultValue="https://localhost:3000/assets/icon-64.png"/>
  <SupportUrl DefaultValue="https://localhost:3000"/>
  <Hosts><Host Name="Workbook"/></Hosts>
  <DefaultSettings><SourceLocation DefaultValue="https://localhost:3000/taskpane.html"/></DefaultSettings>
  <Permissions>ReadWriteDocument</Permissions>
  <VersionOverrides xmlns="http://schemas.microsoft.com/office/taskpaneappversionoverrides" xsi:type="VersionOverridesV1_0">
    <Hosts>
      <Host xsi:type="Workbook">
        <Runtimes><Runtime resid="Taskpane.Url" lifetime="long"/></Runtimes>
        <DesktopFormFactor>
          <GetStarted>
            <Title resid="GetStarted.Title"/>
            <Description resid="GetStarted.Description"/>
            <LearnMoreUrl resid="GetStarted.LearnMoreUrl"/>
          </GetStarted>
          <FunctionFile resid="Taskpane.Url"/>
          <ExtensionPoint xsi:type="PrimaryCommandSurface">
            <CustomTab id="TraceForgeTab">
              <Group id="MapGroup">
                <Label resid="MapGroup.Label"/>
                <Icon><bt:Image size="16" resid="Icon.16x16"/><bt:Image size="32" resid="Icon.32x32"/><bt:Image size="80" resid="Icon.80x80"/></Icon>
                <Control xsi:type="Button" id="FormulaMapTurboButton">
                  <Label resid="FormulaMapTurbo.Label"/>
                  <Supertip><Title resid="FormulaMapTurbo.Label"/><Description resid="FormulaMapTurbo.Tooltip"/></Supertip>
                  <Icon><bt:Image size="16" resid="ConsIc.16x16"/><bt:Image size="32" resid="ConsIc.32x32"/><bt:Image size="80" resid="ConsIc.80x80"/></Icon>
                  <Action xsi:type="ExecuteFunction"><FunctionName>runFormulaMapTurbo</FunctionName></Action>
                </Control>
              </Group>
              <Group id="DeltaGroup">
                <Label resid="DeltaGroup.Label"/>
                <Icon><bt:Image size="16" resid="Icon.16x16"/><bt:Image size="32" resid="Icon.32x32"/><bt:Image size="80" resid="Icon.80x80"/></Icon>
                <Control xsi:type="Button" id="CreateBaseDeltaButton">
                  <Label resid="CreateBaseDelta.Label"/>
                  <Supertip><Title resid="CreateBaseDelta.Label"/><Description resid="CreateBaseDelta.Tooltip"/></Supertip>
                  <Icon><bt:Image size="16" resid="SmFillIc.16x16"/><bt:Image size="32" resid="SmFillIc.32x32"/><bt:Image size="80" resid="SmFillIc.80x80"/></Icon>
                  <Action xsi:type="ExecuteFunction"><FunctionName>createBaseDelta</FunctionName></Action>
                </Control>
                <Control xsi:type="Button" id="RemoveBaseDeltaButton">
                  <Label resid="RemoveBaseDelta.Label"/>
                  <Supertip><Title resid="RemoveBaseDelta.Label"/><Description resid="RemoveBaseDelta.Tooltip"/></Supertip>
                  <Icon><bt:Image size="16" resid="PaneIc.16x16"/><bt:Image size="32" resid="PaneIc.32x32"/><bt:Image size="80" resid="PaneIc.80x80"/></Icon>
                  <Action xsi:type="ExecuteFunction"><FunctionName>removeBaseDelta</FunctionName></Action>
                </Control>
              </Group>
              <Group id="ExploreGroup">
                <Label resid="ExploreGroup.Label"/>
                <Icon><bt:Image size="16" resid="Icon.16x16"/><bt:Image size="32" resid="Icon.32x32"/><bt:Image size="80" resid="Icon.80x80"/></Icon>
                <Control xsi:type="Button" id="ExploreFormulaButton">
                  <Label resid="ExploreFormula.Label"/>
                  <Supertip><Title resid="ExploreFormula.Label"/><Description resid="ExploreFormula.Tooltip"/></Supertip>
                  <Icon><bt:Image size="16" resid="Icon.16x16"/><bt:Image size="32" resid="Icon.32x32"/><bt:Image size="80" resid="Icon.80x80"/></Icon>
                  <Action xsi:type="ExecuteFunction"><FunctionName>exploreFormula</FunctionName></Action>
                </Control>
                <Control xsi:type="Button" id="DataFlowButton">
                  <Label resid="DataFlow.Label"/>
                  <Supertip><Title resid="DataFlow.Label"/><Description resid="DataFlow.Tooltip"/></Supertip>
                  <Icon><bt:Image size="16" resid="AutoClrIc.16x16"/><bt:Image size="32" resid="AutoClrIc.32x32"/><bt:Image size="80" resid="AutoClrIc.80x80"/></Icon>
                  <Action xsi:type="ExecuteFunction"><FunctionName>showDataFlow</FunctionName></Action>
                </Control>
              </Group>
              <Label resid="TraceForgeTab.Label"/>
            </CustomTab>
          </ExtensionPoint>
        </DesktopFormFactor>
      </Host>
    </Hosts>
    <Resources>
      <bt:Images>
        <bt:Image id="Icon.16x16" DefaultValue="https://localhost:3000/assets/icon-16.png"/>
        <bt:Image id="Icon.32x32" DefaultValue="https://localhost:3000/assets/icon-32.png"/>
        <bt:Image id="Icon.80x80" DefaultValue="https://localhost:3000/assets/icon-80.png"/>
        <bt:Image id="ConsIc.16x16" DefaultValue="https://localhost:3000/assets/icons/consistency-16.png"/>
        <bt:Image id="ConsIc.32x32" DefaultValue="https://localhost:3000/assets/icons/consistency-32.png"/>
        <bt:Image id="ConsIc.80x80" DefaultValue="https://localhost:3000/assets/icons/consistency-80.png"/>
        <bt:Image id="SmFillIc.16x16" DefaultValue="https://localhost:3000/assets/icons/smart-fill-16.png"/>
        <bt:Image id="SmFillIc.32x32" DefaultValue="https://localhost:3000/assets/icons/smart-fill-32.png"/>
        <bt:Image id="SmFillIc.80x80" DefaultValue="https://localhost:3000/assets/icons/smart-fill-80.png"/>
        <bt:Image id="AutoClrIc.16x16" DefaultValue="https://localhost:3000/assets/icons/auto-color-16.png"/>
        <bt:Image id="AutoClrIc.32x32" DefaultValue="https://localhost:3000/assets/icons/auto-color-32.png"/>
        <bt:Image id="AutoClrIc.80x80" DefaultValue="https://localhost:3000/assets/icons/auto-color-80.png"/>
        <bt:Image id="PaneIc.16x16" DefaultValue="https://localhost:3000/assets/icons/show-taskpane-16.png"/>
        <bt:Image id="PaneIc.32x32" DefaultValue="https://localhost:3000/assets/icons/show-taskpane-32.png"/>
        <bt:Image id="PaneIc.80x80" DefaultValue="https://localhost:3000/assets/icons/show-taskpane-80.png"/>
      </bt:Images>
      <bt:Urls>
        <bt:Url id="GetStarted.LearnMoreUrl" DefaultValue="https://localhost:3000"/>
        <bt:Url id="Taskpane.Url" DefaultValue="https://localhost:3000/taskpane.html"/>
      </bt:Urls>
      <bt:ShortStrings>
        <bt:String id="GetStarted.Title" DefaultValue="TraceForge is ready"/>
        <bt:String id="TraceForgeTab.Label" DefaultValue="TraceForge"/>
        <bt:String id="MapGroup.Label" DefaultValue="Map"/>
        <bt:String id="DeltaGroup.Label" DefaultValue="Delta"/>
        <bt:String id="ExploreGroup.Label" DefaultValue="Formula"/>
        <bt:String id="FormulaMapTurbo.Label" DefaultValue="Map Formulas"/>
        <bt:String id="CreateBaseDelta.Label" DefaultValue="Create Base + Delta"/>
        <bt:String id="RemoveBaseDelta.Label" DefaultValue="Remove Base + Delta"/>
        <bt:String id="ExploreFormula.Label" DefaultValue="Explore Formula"/>
        <bt:String id="DataFlow.Label" DefaultValue="Data Flow"/>
      </bt:ShortStrings>
      <bt:LongStrings>
        <bt:String id="GetStarted.Description" DefaultValue="Open the TraceForge tab to run model review tools."/>
        <bt:String id="FormulaMapTurbo.Tooltip" DefaultValue="Create a compact formula map for the active sheet."/>
        <bt:String id="CreateBaseDelta.Tooltip" DefaultValue="Create value-only Base and live Delta sheets for the active sheet."/>
        <bt:String id="RemoveBaseDelta.Tooltip" DefaultValue="Remove the Base and Delta sheets for the active sheet."/>
        <bt:String id="ExploreFormula.Tooltip" DefaultValue="Inspect the selected formula as a tree with values and cell locations."/>
        <bt:String id="DataFlow.Tooltip" DefaultValue="Show sheet-to-sheet formula links and highlight linked formula cells."/>
      </bt:LongStrings>
    </Resources>
  </VersionOverrides>
</OfficeApp>

